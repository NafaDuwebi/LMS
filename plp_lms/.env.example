# PLP Learning Management System — Environment Configuration
# Copy this file to .env and fill in your values.
#   cp .env.example .env

# Database connection string.
# SQLite:  sqlite:///./plp_lms.db
# PostgreSQL: postgresql://user:password@host:5432/plp_lms
DATABASE_URL=postgresql://user:password@localhost:5432/plp_lms

# Connection pool settings (PostgreSQL only; ignored by SQLite).
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30

# Secret key for JWT signing, CSRF, and session encryption.
# Must be at least 64 characters. Generate with: python -c "import secrets; print(secrets.token_hex(64))"
SECRET_KEY=replace_with_a_64_character_hex_string

# Organisation name displayed throughout the UI.
ORG_NAME=PL Projects Ltd

# Base URL of the application (used in emails and redirects).
BASE_URL=http://localhost:8000

# SMTP settings for email notifications (welcome emails, password resets, etc.).
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
FROM_EMAIL=training@plprojects.co.uk

# Path to the organisation logo used in certificate PDFs.
ORG_LOGO_PATH=./static/logo.png

# Directory paths for uploaded files and generated certificates.
UPLOAD_DIR=
CERTIFICATE_DIR=

# Maximum upload file size in megabytes (values > 200 trigger a warning).
MAX_UPLOAD_MB=50

# Default certificate validity period in years (0 = no expiry).
DEFAULT_CERT_VALIDITY_YEARS=0

# Data retention period for completed enrolments in years.
DATA_RETENTION_YEARS=3

# Minimum attendance percentage threshold for compliance reporting.
MIN_ATTENDANCE_THRESHOLD=80

# Application environment: "development" or "production".
# In development: HTTP-only cookies, no HTTPS redirect, auto-reload enabled.
# In production: Secure cookies, HTTPS redirect enforced.
ENV=development
